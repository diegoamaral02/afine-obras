import React, { createContext, useContext, useEffect, useState } from "react";
import {
  signInWithEmailAndPassword,
  signOut,
  onAuthStateChanged,
} from "firebase/auth";
import { doc, getDoc } from "firebase/firestore";
import { auth, db } from "../firebase";

const AuthContext = createContext();
export function useAuth() { return useContext(AuthContext); }

export function AuthProvider({ children }) {
  const [currentUser, setCurrentUser] = useState(null);
  const [userProfile, setUserProfile] = useState(null);
  const [loading,     setLoading]     = useState(true);

  async function login(email, password) {
    if (email === "teste@afine.com" && password === "123456") {
      setCurrentUser({ uid: "local-teste", email: "teste@afine.com" });
      setUserProfile({ nome: "Diego (Teste)", perfil: "gestor", obras: [] });
      setLoading(false);
      return;
    }
    return signInWithEmailAndPassword(auth, email, password);
  }

  function logout() {
    if (currentUser?.uid === "local-teste") {
      setCurrentUser(null);
      setUserProfile(null);
      return Promise.resolve();
    }
    return signOut(auth);
  }

  useEffect(() => {
    const unsubscribe = onAuthStateChanged(auth, async (user) => {
      if (!user) {
        setCurrentUser(null);
        setUserProfile(null);
        setLoading(false);
        return;
      }

      setCurrentUser(user);

      try {
        const snap = await getDoc(doc(db, "usuarios", user.uid));
        if (snap.exists()) {
          setUserProfile(snap.data());
        } else {
          setUserProfile({ nome: user.email, perfil: "campo", obras: [] });
        }
      } catch (e) {
        setUserProfile({ nome: user.email, perfil: "campo", obras: [] });
      }

      setLoading(false);
    });
    return unsubscribe;
  }, []);

  return (
    <AuthContext.Provider value={{ currentUser, userProfile, login, logout }}>
      {!loading && children}
    </AuthContext.Provider>
  );
}