// firestore.rules — v2: cobre todas as coleções + preparação multi-tenancy
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function uid()           { return request.auth.uid; }
    function isAuth()        { return request.auth != null; }
    function profile()       { return get(/databases/$(database)/documents/usuarios/$(uid())).data; }
    function perfil()        { return profile().perfil; }
    function isAdmUser()     { return isAuth() && profile().adm == true; }
    // Departamento efetivo: usa "departamento" (sistema novo) se existir,
    // senão cai para "perfil" (sistema legado) — mesma lógica do app (JS).
    function dep() {
      return ('departamento' in profile()) ? profile().departamento : perfil();
    }
    // BUG CORRIGIDO: isGestor()/isEncarregado() só reconheciam o perfil legado
    // ("gestor"/"encarregado"), ignorando o campo "departamento" do sistema
    // novo e a flag "adm". Isso bloqueava silenciosamente usuários cadastrados
    // só com departamento (ex: gestao, financeiro, comercial, fiscal, compras)
    // em praticamente toda escrita do sistema (Obras, Compras, Financeiro,
    // Agendamentos, Fornecedores, Clientes, etc.).
    function isGestor()      { return isAuth() && (isAdmUser() || dep() == 'gestao' || dep() == 'gestor' || dep() == 'adm'); }
    function isEncarregado() { return isAuth() && (isGestor() || dep() == 'encarregado' ||
                                  dep() == 'financeiro' || dep() == 'comercial' || dep() == 'fiscal' || dep() == 'compras'); }
    function isCampo()       { return isAuth(); }
    // Detecta departamento "campo" considerando tanto o sistema novo (departamento)
    // quanto o legado (perfil) — usado para bloquear criação de manutenções
    // diretamente pelo app de campo (ANEXO 1/2 — não permitir que campo crie)
    function isCampoDept() {
      return isAuth() && profile().adm != true &&
        (profile().departamento == 'campo' ||
         (!('departamento' in profile()) && perfil() == 'campo'));
    }
    function obraPermitida(obraId) {
      return isGestor() || profile().obras.hasAny([obraId]);
    }

    // ── Usuários ─────────────────────────────────────────────────
    match /usuarios/{id} {
      allow read:   if isAuth() && (uid() == id || isGestor());
      allow create: if isGestor();
      allow update: if isAuth() && (uid() == id || isGestor());
      allow delete: if isGestor();
    }

    // ── Obras ────────────────────────────────────────────────────
    match /obras/{id} {
      allow read:   if isAuth();
      allow create: if isEncarregado();
      allow update: if isEncarregado();
      allow delete: if isGestor();
      // Subcoleção de histórico (auditoria)
      match /historico/{hid} {
        allow read:  if isEncarregado();
        allow write: if isAuth();
      }
    }

    // ── Manutenções ──────────────────────────────────────────────
    match /manutencoes/{id} {
      allow read:   if isAuth();
      allow create: if isAuth() && !isCampoDept();
      allow update: if isAuth();
      allow delete: if isEncarregado();
      match /historico/{hid} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Escopos ──────────────────────────────────────────────────
    match /escopos/{id} {
      allow read:   if isAuth();
      allow create: if isEncarregado();
      allow update: if isAuth();
      allow delete: if isEncarregado();
    }

    // ── RDOs (Diário de Obra) ─────────────────────────────────────
    match /rdos/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isEncarregado();
      allow delete: if isGestor();
    }

    // ── Equipe ───────────────────────────────────────────────────
    match /equipe/{id} {
      allow read:  if isAuth();
      allow write: if isEncarregado();
    }

    // ── Ocorrências ───────────────────────────────────────────────
    match /ocorrencias/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isEncarregado();
      allow delete: if isGestor();
    }

    // ── Materiais / Estoque ───────────────────────────────────────
    // BUG CORRIGIDO: campo precisa registrar saída de estoque ao usar
    // material durante a execução de obras/manutenções (unificação real do
    // controle de estoque), mas a regra exigia isEncarregado() pra qualquer
    // escrita — bloqueando exatamente quem mais usa essa funcionalidade.
    match /materiais_estoque/{id} {
      allow read:   if isAuth();
      allow create: if isEncarregado();      // só gestão pode criar item novo do zero
      allow update: if isAuth();             // campo pode debitar/creditar saldo ao usar/devolver material
      allow delete: if isGestor();
    }
    match /movimentacoes/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();             // qualquer um registra a própria movimentação (uso em campo)
      allow update: if isEncarregado();
      allow delete: if isGestor();
    }

    // ── FINANCEIRO (apenas gestor) ───────────────────────────────
    match /financeiro/{id} {
      allow read:   if isGestor();
      allow write:  if isGestor();
      match /historico/{hid} {
        allow read:  if isGestor();
        allow write: if isGestor();
      }
    }

    // ── Compras ──────────────────────────────────────────────────
    match /compras/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isEncarregado();
      allow delete: if isGestor();
      match /historico/{hid} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Despesas / reembolsos (novo — migrado do controle de planilha) ─
    match /despesas/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isEncarregado();
      allow delete: if isGestor();
      match /historico/{hid} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Custos vinculados a demandas (obras/manutenções) ─────────────
    // Empreiteiro, terceiro e campo podem lançar; gestão aprova e exclui.
    match /custos_demanda/{id} {
      allow read:   if isAuth();
      allow create: if isCampo();        // qualquer usuário autenticado lança
      allow update: if isEncarregado();  // aprovação, status, edição
      allow delete: if isGestor();
    }

    // ── Transferências de material entre obras ──────────────────────
    match /transferencias_material/{id} {
      allow read:   if isAuth();
      allow create: if isEncarregado();
      allow update: if isEncarregado();
      allow delete: if isGestor();
      match /historico/{hid} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Fornecedores ──────────────────────────────────────────────
    match /fornecedores/{id} {
      allow read:  if isAuth();
      allow write: if isEncarregado();
    }

    // ── Clientes (COMERCIAL — apenas gestor/encarregado) ─────────
    match /clientes/{id} {
      allow read:  if isEncarregado();
      allow write: if isEncarregado();
    }

    // ── Oportunidades (funil de vendas) ──────────────────────────
    match /oportunidades/{id} {
      allow read:  if isEncarregado();
      allow write: if isEncarregado();
    }

    // ── Agendamentos ──────────────────────────────────────────────
    match /agendamentos/{id} {
      allow read:  if isAuth();
      allow write: if isEncarregado();
    }

    // ── Boletins de Medição ───────────────────────────────────────
    match /boletins/{id} {
      allow read:  if isAuth();
      allow write: if isEncarregado();
    }

    // ── FVS (Ficha de Verificação) ────────────────────────────────
    match /fvs/{id} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── Log de Auditoria (append-only) ────────────────────────────
    match /audit_log/{id} {
      allow read:  if isGestor();
      allow create: if isAuth();
      allow update: if false;   // imutável
      allow delete: if false;   // imutável
    }

    // ── Notificações (por usuário) ────────────────────────────────
    match /notificacoes/{uid_destino}/{id} {
      allow read:   if isAuth() && uid() == uid_destino;
      allow write:  if isAuth();
    }
  }
}
